# Database
DATABASE_URL=postgresql://boxing:boxing@db:5432/boxingclub

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001

# CORS — lista de origens permitidas separadas por vírgula.
# Em dev (Docker), deixe vazio: o valor de WEB_URL acima é usado como fallback.
# Em produção, preencha com a URL do Cloudflare Pages (e a URL local se quiser testar):
#   ALLOWED_ORIGINS=https://boxingclub.pages.dev,http://localhost:5173
ALLOWED_ORIGINS=

# Demo flag — define se o ambiente atual é a versão de portfólio pública.
# Não altera lógica de negócio; serve para avisos e identificação do ambiente.
# Em dev: false (ou deixe vazio). No Render (demo): IS_DEMO=true
IS_DEMO=false

# Email (Resend)
# IMPORTANTE para a demo pública:
#   - Crie uma API key SEPARADA e DEDICADA à demo no painel do Resend
#     (Settings → API Keys → Create API Key). Use o mesmo domínio já verificado,
#     mas uma chave nova, para poder revogar sem afetar e-mails reais fora da demo.
#   - Se RESEND_API_KEY não estiver definido, novos cadastros são auto-verificados
#     (o usuário pode logar sem confirmar e-mail). Útil como rede de segurança,
#     mas na demo pública a chave DEVE estar configurada para o fluxo completo funcionar.
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Boxing Club <noreply@boxingclub.com>

# Mercado Pago
# DEMO PÚBLICA: deixe estas três variáveis VAZIAS / não definidas intencionalmente.
# Sem elas, pedidos ficam com status "pendente" e assinaturas retornam erro amigável
# (a lógica de degradação graciosa já está implementada no backend).
# Em produção real, preencha com suas credenciais do Mercado Pago.
MP_ACCESS_TOKEN=TEST-your-access-token-here
MP_PUBLIC_KEY=TEST-your-public-key-here
MP_WEBHOOK_SECRET=your-webhook-secret-here

# Frontend (Vite)
# Em produção (Cloudflare Pages), configure VITE_API_URL com a URL pública do
# backend no Render (ex: https://boxingclub-api.onrender.com).
# Em dev (Docker), o proxy /api já redireciona para o backend — deixe comentado.
VITE_API_URL=http://localhost:3001
VITE_MP_PUBLIC_KEY=TEST-your-public-key-here

# Banner de demo no frontend — exibe aviso de "versão demo de portfólio".
# Em dev: false (ou deixe vazio). No Cloudflare Pages (demo): VITE_IS_DEMO=true
VITE_IS_DEMO=false
