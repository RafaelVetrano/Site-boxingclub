# Database
DATABASE_URL=postgresql://boxing:boxing@db:5432/boxingclub

# JWT
JWT_ACCESS_SECRET=change-me-access-secret-at-least-32-chars
JWT_REFRESH_SECRET=change-me-refresh-secret-at-least-32-chars
JWT_ACCESS_EXPIRES=15m
JWT_REFRESH_EXPIRES=7d

# Server
NODE_ENV=development
API_PORT=3001
WEB_URL=http://localhost:5173
API_URL=http://localhost:3001

# Email (Resend)
RESEND_API_KEY=re_your_key_here
EMAIL_FROM=Boxing Club <noreply@boxingclub.com>

# Mercado Pago
MP_ACCESS_TOKEN=TEST-your-access-token-here
MP_PUBLIC_KEY=TEST-your-public-key-here
MP_WEBHOOK_SECRET=your-webhook-secret-here

# Frontend
VITE_API_URL=http://localhost:3001
VITE_MP_PUBLIC_KEY=TEST-your-public-key-here
